    "dotenv": "^16.0.3",
    "express-validator": "^7.0.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.2.5",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/express-rate-limit": "^6.0.0",
    "typescript": "^5.0.4",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.1",
    "axios": "^1.4.0"
