{
  "name": "@hrs/api",
  "version": "0.1.0",
  "description": "API for Human Resource System",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
